---
const currentYear = new Date().getFullYear();

const footerLinks = {
  product: [
    { href: '/why', label: 'Why .prompt' },
    { href: '/use-cases', label: 'Use Cases' },
    { href: '/docs', label: 'Documentation' },
  ],
  community: [
    { href: 'https://github.com/dot-prompt/dot-prompt', label: 'GitHub' },
  ],
  resources: [
    { href: '/docs/getting-started', label: 'Getting Started' },
    { href: '/docs/language-reference', label: 'Language Reference' },
  ],
};
---

<footer class="border-t border-[var(--color-border)]">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div class="flex items-center gap-6">
        {footerLinks.product.map((link) => (
          <a href={link.href} class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">
            {link.label}
          </a>
        ))}
        {footerLinks.community.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">
            {link.label}
          </a>
        ))}
      </div>
      <p class="text-xs text-[var(--color-text-muted)]">
        &copy; {currentYear} dot-prompt
      </p>
    </div>
  </div>
</footer>
