---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const exampleCode = `init do
  @version: 1.0
  @major: 1

  params:
    @skills: list[str]
    @tone: enum[formal, casual, friendly] = friendly
    @context: str

  fragments:
    {skill_context}: static from: skills
      match: @skills
    {tone_guide}: static from: prompts/tone
      match: @tone
    {{user_context}}: dynamic

end init

# Compose from fragments
{skill_context}

{tone_guide}

Context: @context

{{user_context}}

response do
  {
    "skills_applied": @skills,
    "tone_used": "@tone"
  }
end response`;
---

<MarketingLayout title="Fragment Composition - Use Cases">
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <nav class="mb-8">
          <a href="/use-cases" class="text-primary-600 hover:underline">&larr; Back to Use Cases</a>
        </nav>
        <div class="text-4xl mb-4">🧩</div>
        <h1 class="text-4xl font-bold">Fragment Composition</h1>
        <p class="mt-4 text-xl text-[var(--color-text-muted)]">
          Build prompts from reusable, composable pieces.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-2xl font-bold mb-6">The Challenge</h2>
        <p class="text-[var(--color-text-muted)] mb-6">
          Large prompts often repeat common sections. Copy-pasting leads to drift. Updating one section means finding and updating every copy.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 bg-[var(--color-surface)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-2xl font-bold mb-6">The Solution</h2>
        <p class="text-[var(--color-text-muted)] mb-6">
          Break your prompts into reusable fragments. Reference them by name. The compiler composes them into a single prompt.
        </p>
        <CodeBlock code={exampleCode} title="composed.prompt" language="dotprompt" />
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-2xl font-bold mb-6">Fragment Types</h2>
        <div class="space-y-6">
          <div class="rounded-lg border border-[var(--color-border)] p-4">
            <h3 class="font-semibold mb-2">Static Fragments <code class="text-primary-600">{`{name}`}</code></h3>
            <p class="text-[var(--color-text-muted)]">
              Cached at compile time. Loaded from files or folders. Perfect for skills, tone guides, and other reusable content.
            </p>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] p-4">
            <h3 class="font-semibold mb-2">Dynamic Fragments <code class="text-primary-600">{`{{name}}`}</code></h3>
            <p class="text-[var(--color-text-muted)]">
              Fetched fresh each request. Useful for user-specific context that changes with every call.
            </p>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] p-4">
            <h3 class="font-semibold mb-2">Collections</h3>
            <p class="text-[var(--color-text-muted)]">
              Load multiple fragments from a folder. Composite them in order. Great for building skills libraries.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-2xl font-bold mb-6">Key Benefits</h2>
        <ul class="space-y-4">
          <li class="flex gap-3">
            <svg class="h-6 w-6 shrink-0 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Update once, apply everywhere</span>
          </li>
          <li class="flex gap-3">
            <svg class="h-6 w-6 shrink-0 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Static fragments are cached for performance</span>
          </li>
          <li class="flex gap-3">
            <svg class="h-6 w-6 shrink-0 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>Fragments can be versioned independently</span>
          </li>
        </ul>
      </div>
    </div>
  </section>
</MarketingLayout>
