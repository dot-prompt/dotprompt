---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const baseUrlCode = `http://localhost:4041`;

const renderRequestCode = `{
  "prompt": "hello",
  "params": {
    "variation": "analogy"
  },
  "runtime": {
    "user_input": "What is recursion?"
  },
  "seed": 42
}`;

const renderResponseCode = `{
  "prompt": "...",
  "response_contract": {...}
}`;

const compileRequestCode = `{
  "prompt": "hello",
  "params": {...}
}`;

const injectRequestCode = `{
  "template": "Hello, @name!",
  "runtime": { "name": "World" }
}`;

const versionActionCode = `{
  "prompt": "hello",
  "action": "bump_major"
}`;

const pythonClientCode = `from dot_prompt import Client

client = Client("http://localhost:4041")

result = client.render(
    "concept_explanation",
    params={
        "pattern_step": 2,
        "variation": "recognition"
    },
    runtime={
        "user_input": "Can you give me an example?"
    },
    seed=42
)

result["prompt"]             # compiled string
result["response_contract"]  # derived schema`;

const errorResponseCode = `{
  "error": "validation_error",
  "message": "Parameter 'age' must be an integer",
  "details": {...}
}`;
---

<DocsLayout 
  title="API Reference" 
  activeSlug="/docs/api-reference"
  description="HTTP API endpoints for .prompt"
>
  <h1>API Reference</h1>
  <p>
    The container exposes an HTTP API for compiling and rendering prompts.
  </p>

  <h2>Base URL</h2>
  <CodeBlock code={baseUrlCode} language="bash" />

  <h2>Endpoints</h2>

  <h3>Render Prompt</h3>
  <p>
    <code>POST /api/render</code> — Compile and inject in one call
  </p>
  <CodeBlock code={renderRequestCode} language="json" />

  <h4>Response</h4>
  <CodeBlock code={renderResponseCode} language="json" />

  <h3>Compile</h3>
  <p>
    <code>POST /api/compile</code> — Resolve control flow, return template
  </p>
  <CodeBlock code={compileRequestCode} language="json" />

  <h3>Inject</h3>
  <p>
    <code>POST /api/inject</code> — Fill runtime variables into template
  </p>
  <CodeBlock code={injectRequestCode} language="json" />

  <h3>Get Schema</h3>
  <p>
    <code>GET /api/schema/:prompt</code> — Schema for latest major version
  </p>
  <p>
    <code>GET /api/schema/:prompt/:major</code> — Schema for specific major version
  </p>

  <h3>List Prompts</h3>
  <p>
    <code>GET /api/prompts</code> — List all prompt files
  </p>

  <h3>List Collections</h3>
  <p>
    <code>GET /api/collections</code> — List all collections
  </p>

  <h3>Events</h3>
  <p>
    <code>GET /api/events</code> — SSE stream for VS Code integration
  </p>

  <h3>Version</h3>
  <p>
    <code>POST /api/version</code> — Trigger version action
  </p>
  <CodeBlock code={versionActionCode} language="json" />

  <h3>Webhooks</h3>
  <p>
    <code>POST /webhooks/commit</code> — Post-commit hook receiver
  </p>

  <h2>Python Client</h2>
  <CodeBlock code={pythonClientCode} language="python" />

  <h2>Error Responses</h2>
  <CodeBlock code={errorResponseCode} language="json" />

  <h2>Next Steps</h2>
  <ul>
    <li><a href="/docs/getting-started">Getting Started</a> — Quick start</li>
    <li><a href="/use-cases">Use Cases</a> — Real-world examples</li>
  </ul>
</DocsLayout>
