---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const versionFieldsCode = `init do
  @major: 1      # Stability version — callers pin to this
  @version: 1.3  # Precise version (major.minor)
end init`;

const folderStructureCode = `priv/prompts/
├── concept_explanation.prompt  # current — always latest
├── practice.prompt
├── skills/
│   ├── milton_model.prompt
│   ├── meta_model.prompt
│   └── archive/
│       └── milton_model_v1.prompt
└── archive/
    └── concept_explanation_v1.prompt`;

const callersCode = `client.render(
    "concept_explanation",
    major=1,  # Get latest 1.x.x
    params={...}
)`;
---

<DocsLayout 
  title="Versioning" 
  activeSlug="/docs/versioning"
  description="Semantic versioning for .prompt files"
>
  <h1>Versioning</h1>
  <p>
    .prompt uses semantic versioning to manage changes and ensure backward compatibility. Both the prompt and its contract are versioned together.
  </p>

  <h2>Version Fields</h2>
  <CodeBlock code={versionFieldsCode} language="dotprompt" />

  <table>
    <thead>
      <tr>
        <th>Field</th>
        <th>Managed By</th>
        <th>Purpose</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><code>@major</code></td>
        <td>Developer</td>
        <td>Stability — bumping major allows breaking changes</td>
      </tr>
      <tr>
        <td><code>@version</code></td>
        <td>Container/Dev</td>
        <td>Precision — managed via major.minor format</td>
      </tr>
    </tbody>
  </table>

  <h2>Breaking Changes</h2>
  <p>
    These require bumping <code>@major</code>:
  </p>
  <ul>
    <li>Removing or renaming parameters</li>
    <li>Changing parameter types</li>
    <li>Removing response fields</li>
    <li>Changing response field types</li>
  </ul>

  <h2>Non-Breaking Changes</h2>
  <p>
    These auto-bump <code>@minor</code>:
  </p>
  <ul>
    <li>Adding parameters with defaults</li>
    <li>Adding optional response fields</li>
    <li>Changing documentation</li>
    <li>Editing prompt content</li>
  </ul>

  <h2>How It Works</h2>
  <ol>
    <li>
      <strong>You edit</strong> a .prompt file and save
    </li>
    <li>
      <strong>Container detects</strong> what changed
    </li>
    <li>
      <strong>If breaking</strong> — prompts you to bump major version
    </li>
    <li>
      <strong>If non-breaking</strong> — auto-bumps minor on commit
    </li>
    <li>
      <strong>Old version</strong> archived to <code>archive/</code>
    </li>
  </ol>

  <h2>Folder Structure</h2>
  <CodeBlock code={folderStructureCode} language="markdown" />

  <h2>For Callers</h2>
  <p>
    Pin to a major version to receive non-breaking updates automatically:
  </p>

  <CodeBlock code={callersCode} language="python" />

  <h2>Breaking Change Detection</h2>

  <h2>Breaking Change Detection</h2>
  <p>
    The container warns you on save and gives a hard warning at git commit if unversioned breaking changes exist.
  </p>

  <h2>Next Steps</h2>
  <ul>
    <li><a href="/docs/api-reference">API Reference</a> — HTTP endpoints</li>
    <li><a href="/docs/getting-started">Getting Started</a> — Quick start guide</li>
  </ul>
</DocsLayout>
