---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const basicResponseCode = `response do
  {
    "response_type": "greeting",
    "content": "..."
  }
end response`;

const schemaCode = `{
  "type": "object",
  "properties": {
    "response_type": { "type": "string", "enum": ["greeting"] },
    "content": { "type": "string" }
  },
  "required": ["response_type", "content"]
}`;

const nestedResponseCode = `response do
  {
    "user": {
      "name": "...",
      "preferences": {
        "theme": "..."
      }
    }
  }
end response`;

const compatibilityCode = `if @is_premium is true do
Premium content here.

response do
  {
    "content": "...",
    "premium_features": ["a", "b", "c"]
  }
end response

else
Free content here.

response do
  {
    "content": "..."
  }
end response

end @is_premium`;

const variablesInResponseCode = `response do
  {
    "response_type": "teaching",
    "step": @current_step,
    "next_step": @current_step + 1
  }
end response`;

const validationCode = `{
  "prompt": "...",
  "response_contract": {
    "type": "object",
    "properties": {
      "response_type": { "type": "string" },
      "content": { "type": "string" }
    }
  }
}`;
---

<DocsLayout 
  title="Response Contracts" 
  activeSlug="/docs/response-contracts"
  description="Output schema definition in .prompt"
>
  <h1>Response Contracts</h1>
  <p>
    Response contracts define the expected output structure from your LLM. They version together with your prompt and are derived automatically from JSON blocks.
  </p>

  <h2>Basic Response Contract</h2>
  <CodeBlock code={basicResponseCode} language="dotprompt" />

  <p>
    The compiler derives the schema from the JSON structure:
  </p>

  <CodeBlock code={schemaCode} language="json" />

  <h2>Nested Objects</h2>
  <CodeBlock code={nestedResponseCode} language="dotprompt" />

  <h2>Multiple Response Blocks</h2>
  <p>
    You can have multiple response blocks in different branches. The compiler validates compatibility:
  </p>

  <CodeBlock code={compatibilityCode} language="dotprompt" />

  <h3>Compatibility Rules</h3>
  <ul>
    <li><strong>Compatible</strong> — Fields in common have matching types</li>
    <li><strong>Warning</strong> — Some fields differ but are compatible</li>
    <li><strong>Error</strong> — Incompatible types for the same field</li>
  </ul>

  <h2>Using Variables</h2>
  <p>
    Reference variables in response contracts:
  </p>

  <CodeBlock code={variablesInResponseCode} language="dotprompt" />

  <h2>Contract Validation</h2>
  <p>
    The derived schema is returned with every compiled prompt. Your application can validate LLM responses against the contract:
  </p>

  <CodeBlock code={validationCode} language="json" />

  <h2>Benefits</h2>
  <ul>
    <li>Automatic schema derivation</li>
    <li>Versioned with the prompt</li>
    <li>Breaking change detection</li>
    <li>Runtime validation support</li>
  </ul>

  <h2>Next Steps</h2>
  <ul>
    <li><a href="/docs/versioning">Versioning</a> — Semantic versioning for contracts</li>
    <li><a href="/docs/api-reference">API Reference</a> — HTTP endpoints</li>
  </ul>
</DocsLayout>
