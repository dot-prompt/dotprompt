---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import CodeBlock from '../components/CodeBlock.astro';

const exampleCode = `init do
  @version: 1.0
  @major: 1

  def:
    mode: explanation
    description: Teacher mode.

  params:
    @pattern_step: int[1..5] = 1
    @variation: enum[analogy, recognition]
    @user_input: str

end init

case @variation do
analogy: Use an analogy to explain.
recognition: Ask a guiding question.
end @variation

@user_input

response do
  {
    "response_type": "teaching",
    "content": "..."
  }
end response`;

const compiledOutput = `Ask a guiding question.

[user message]

Respond with this JSON:
{
  "response_type": "teaching",
  "content": "..."
}`;
---

<MarketingLayout title=".prompt - A Compiled Language for LLM Prompts">
  <!-- Hero Section -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-3xl font-bold tracking-tight sm:text-5xl leading-tight">
          A compiled language for <span class="text-gradient">LLM prompts</span>
        </h1>
        <p class="mt-6 text-base text-[var(--color-text-muted)] leading-relaxed max-w-xl">
          Define structure, branching, and contracts in <code class="text-sm font-mono bg-[var(--color-surface)] px-1.5 py-0.5 rounded">.prompt</code> files. Compile away the complexity before it reaches your model.
        </p>
        <div class="mt-8 flex items-center gap-4">
          <a href="/docs/getting-started" class="btn btn-primary">
            Get Started
          </a>
          <a href="/why" class="btn btn-secondary">
            Why .prompt?
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Code Example Section -->
  <section class="py-12 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-lg font-semibold">Write once, compile clean</h2>
        <p class="mt-2 text-sm text-[var(--color-text-muted)] mb-6">
          Branching resolves at compile time. The LLM receives only what it needs.
        </p>
        <CodeBlock code={exampleCode} title="example.prompt" language="dotprompt" />
        <div class="mt-6">
          <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wide mb-2">
            Compiled output for <code class="font-mono text-[var(--color-accent)]">variation: recognition</code>:
          </p>
        </div>
        <CodeBlock code={compiledOutput} title="output" language="markdown" />
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-semibold mb-12">Everything you need for prompt engineering</h2>
      <div class="grid grid-cols-1 gap-px bg-[var(--color-border)] md:grid-cols-2 lg:grid-cols-3">
        <div class="bg-[var(--color-bg)] p-6">
          <h3 class="text-sm font-semibold">Compile-Time Resolution</h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">
            <code class="text-xs font-mono">if</code>, <code class="text-xs font-mono">case</code>, and <code class="text-xs font-mono">vary</code> blocks resolve before the LLM call. No branching logic reaches your model.
          </p>
        </div>
        <div class="bg-[var(--color-bg)] p-6">
          <h3 class="text-sm font-semibold">Input & Output Contracts</h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">
            Declare params and response schemas. Both version together. Breaking changes are detected automatically.
          </p>
        </div>
        <div class="bg-[var(--color-bg)] p-6">
          <h3 class="text-sm font-semibold">Fragment Composition</h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">
            Compose prompts from reusable fragments. Static fragments are cached. Dynamic fragments fetch fresh each request.
          </p>
        </div>
        <div class="bg-[var(--color-bg)] p-6">
          <h3 class="text-sm font-semibold">Semantic Versioning</h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">
            Pin callers to major versions. Old versions are archived. Breaking changes require bumping the major version.
          </p>
        </div>
        <div class="bg-[var(--color-bg)] p-6">
          <h3 class="text-sm font-semibold">Three Cache Layers</h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">
            Structural skeleton cached by compile-time params. Vary branches preloaded at startup. Fragment content cached by path.
          </p>
        </div>
        <div class="bg-[var(--color-bg)] p-6">
          <h3 class="text-sm font-semibold">MCP Server</h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">
            Connect your LLM coding tools via MCP. Discover prompt schemas, params, and contracts without reading files.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="bg-[var(--color-surface)] p-8 sm:p-12">
        <h2 class="text-xl font-semibold">
          Ready to clean up your prompts?
        </h2>
        <p class="mt-2 text-sm text-[var(--color-text-muted)] mb-6">
          Start with a clean compile-to-LLM workflow today.
        </p>
        <a href="/docs/getting-started" class="btn btn-primary">
          Get Started
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
