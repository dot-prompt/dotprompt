  @major: 1

  def:
    mode: analysis
    description: Analysis Agent - Student practice history analysis

  params:
    @student_history: str
    @mastery_scores: str

  docs do
    Analyzes student practice history and mastery scores to provide strengths and growth feedback.
  end docs

