init do
  @version: 1.0
  @major: 1

  def:
    mode: stats
    description: Stats Agent - Student statistics and progress analysis
    role: assistant

  params:
    @student_data: str
    @skill_list: str

  docs do
    Analyzes student statistics and provides progress insights.
  end docs

end init

system do
You are a statistics and analytics agent for the NLP Trainer app.
Analyze student data and provide insights about their learning progress.
end system

context do
Student Data:
@student_data

Available Skills:
@skill_list
end context

user do
Provide statistics analysis.
end user
