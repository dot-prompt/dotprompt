{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{{", "}}"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{{", "close": "}}" },
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(.*\\bdo\\b|.*:\\s*)$",
    "decreaseIndentPattern": "^\\s*(end|elif|else)\\b"
  }
}
