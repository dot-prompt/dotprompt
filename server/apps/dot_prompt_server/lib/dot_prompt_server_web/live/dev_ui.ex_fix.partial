  defp load_prompt_file(name) do
    path = Path.join(DotPrompt.prompts_dir(), "#{name}.prompt")

    if File.exists?(path) do
      File.read!(path)
    else
      ""
    end
  end

  defp prepare_params(params) do
    params
    |> Enum.reject(fn {_, v} -> v == "" or v == nil end)
    |> Enum.into(%{})
  end

  defp estimate_tokens(text) when is_binary(text) do
    words = length(String.split(text))
    div(words * 4, 3)
  end

  def render_markdown(text) do
    case Earmark.as_html(text || "") do
      {:ok, html, _messages} ->
        html
        |> Phoenix.HTML.raw()

      _ ->
        text
        |> Phoenix.HTML.html_escape()
        |> Phoenix.HTML.safe_to_string()
        |> Phoenix.HTML.raw()
    end
  end

  def highlight_compiled_content(text, compile_params, collapsed_sections, vary_selections, section_popover)
      when is_binary(text) and is_map(compile_params) do
    # Parse the text into sections
    lines = String.split(text, "\n")

    {html_output, _state} =
      Enum.reduce(lines, {"", %{section_stack: [], line_no: 1, visible: true, in_list: false}}, fn line, {acc, state} ->
        cond do
          # Start of section: [[section:type:indent:id:var:options:label]]
          String.match?(line, ~r/^\[\[section:(.*?):(.*?):(.*?):(.*?):(.*?):(.*?)$/) ->
            # Close any open list
            {list_close, state} = close_list(state)

            [_, type, indent_str, id, var_name, options_str, label] =
              Regex.run(~r/^\[\[section:(.*?):(.*?):(.*?):(.*?):(.*?):(.*?)$/, line)

            label = String.trim_trailing(label, "]]")
            indent_level = String.to_integer(indent_str)
            options = String.split(options_str, ",", trim: true)

            is_collapsed = MapSet.member?(collapsed_sections, id)
            is_popover_open = section_popover == id

            # Enrich label for vary sections
            final_label = 
              if type == "vary" do
                selection = Map.get(vary_selections, label) || "?"
                "#{label} → #{selection}"
              else
                label
              end

            # Map types to colors from dot_prompt_editor_v4.html
            color_class =
              case type do
                "branch" -> "ab-gr"
                "case" -> "ab-gr"
                "frag" -> "ab-bl"
                "vary" -> "ab-pu"
                _ -> "ab-mu"
              end

            # Content highlighting
            content_hl =
              case type do
                "branch" -> "hl-gr"
                "case" -> "hl-gr"
                "frag" -> "hl-bl"
                "vary" -> "hl-pu"
                _ -> ""
              end

            # Section header is visible only if its parent is visible
            header_html =
              if state.visible do
                popover_html = if is_popover_open and options != [] do
                  """
                  <div class="popover show" style="top: 24px; left: 0; width: 180px; font-style: normal;">
                    <div class="pop-head" style="margin-bottom:4px">Select Value <span class="pop-close" phx-click="close_section_popover">×</span></div>
                    <div class="pbody" style="padding: 2px;">
                      #{Enum.map(options, fn opt -> 
                        """
                        <div class="pf-row" phx-click="update_section_param" phx-value-var="#{var_name}" phx-value-val="#{opt}">
                          <span class="pf-lbl">#{opt}</span>
                        </div>
                        """
                      end) |> Enum.join("")}
                    </div>
                  </div>
                  """
                else
                  ""
                end

                """
                #{list_close}
                <div class="cl ann" style="position: relative;">
                  <span class="ln"></span>
                  <span class="cc" style="padding-left: calc(#{indent_level} * 1.5rem); display: flex; align-items: center; gap: 8px;">
                    <span class="ab #{color_class}" phx-click="toggle_section_popover" phx-value-id="#{id}">#{final_label}</span>
                    <span class={"chev #{if !is_collapsed, do: "open"}"} phx-click="toggle_collapse" phx-value-group="#{id}">›</span>
                    #{popover_html}
                  </span>
                </div>
                """
              else
                list_close
              end

            # New visibility: parent must be visible AND this section must not be collapsed
            new_visible = state.visible and !is_collapsed

            new_stack = [
              %{type: type, hl: content_hl, id: id, was_visible: state.visible}
              | state.section_stack
            ]

            {acc <> header_html, %{state | section_stack: new_stack, visible: new_visible, in_list: false}}

          # End of section
          line == "[[/section]]" ->
            {list_close, state} = close_list(state)

            {new_stack, old_visible} =
              case state.section_stack do
                [%{was_visible: v} | rest] -> {rest, v}
                [] -> {[], true}
              end

            {acc <> list_close, %{state | section_stack: new_stack, visible: old_visible, in_list: false}}

          # Normal line
          true ->
            # Get current highlighting from stack
            current_hl =
              case state.section_stack do
                [%{hl: hl} | _] -> hl
                _ -> ""
              end

            # Don't show empty lines that are just padding for sections
            if line == "" and current_hl != "" do
              {acc, state}
            else
              if state.visible do
                highlighted_line =
                  line
                  |> Phoenix.HTML.html_escape()
                  |> Phoenix.HTML.safe_to_string()
                  |> String.replace("&#39;", "'")
                  |> String.replace("&quot;", "\"")
                  |> render_markdown_inline()
                  |> highlight_runtime_vars()
                  |> highlight_param_values(compile_params)

                row_html = """
                <div class="cl #{current_hl}">
                  <span class="ln">#{state.line_no}</span>
                  <span class="cc">#{highlighted_line}</span>
                </div>
                """

                {acc <> row_html, %{state | line_no: state.line_no + 1}}
              else
                {acc, state}
              end
            end
        end
      end)

    # Final cleanup if still in list
    final_acc = 
      case html_output do
        {acc, state} -> 
          {close, _} = close_list(state)
          acc <> close
        acc -> acc
      end

    Phoenix.HTML.raw(final_acc)
  end

  def highlight_compiled_content(text, compile_params, collapsed_sections) do
    highlight_compiled_content(text, compile_params, collapsed_sections, %{}, nil)
  end

  def highlight_compiled_content(text, compile_params) do
    highlight_compiled_content(text, compile_params, MapSet.new(), %{}, nil)
  end

  defp open_list(%{in_list: false} = state), do: {"<ul class='mlist'>", %{state | in_list: true}}
  defp open_list(state), do: {"", state}

  defp close_list(%{in_list: true} = state), do: {"</ul>", %{state | in_list: false}}
  defp close_list(state), do: {"", state}

  defp highlight_runtime_vars(text) do
    String.replace(text, ~r/(\{\{[^}]+\}\})/, "<span class=\"rtv\">\\1</span>")
  end

  defp highlight_param_values(text, compile_params) do
    Enum.reduce(compile_params, text, fn {param_name, value}, acc ->
      if is_binary(value) and value != "" and String.length(value) > 1 do
        escaped_value = Regex.escape(value) |> IO.iodata_to_binary()
        # Ensure we match whole words or values not inside tags
        pattern = ~r/(?<![^>\s])#{escaped_value}(?![<\s])/
        replacement = "<span class=\"pv\" title=\"@#{param_name}\">#{value}</span>"
        Regex.replace(pattern, acc, replacement)
      else
        acc
      end
    end)
  end

  defp render_markdown_inline(text) do
    # Handle inline markdown: **bold**, *italic*, `code`
    text
    |> String.replace(~r/\*\*(.+?)\*\*/, "<strong>\\1</strong>")
    |> String.replace(~r/\*(.+?)\*/, "<em>\\1</em>")
    |> String.replace(~r/`(.+?)`/, "<code>\\1</code>")
  end

  defp preview_version(current, type) do
    case type do
      :patch -> "#{current}.1"
      :minor -> "#{current + 1}.0"
      :major -> "#{current + 1}.0.0"
    end
  end

  defp param_sort_weight(type) do
    case type do
      :list_enum -> 1
      :enum -> 2
      :bool -> 3
      :int -> 4
      _ -> 10
    end
  end
end
