<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="dot-prompt Dev UI" />
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <.live_title suffix=" · dot-prompt">
      <%= assigns[:page_title] || "Dev" %>
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }      :root {
        --bg: #050608; 
        --s1: rgba(14, 16, 20, 0.85); 
        --s2: rgba(20, 23, 29, 0.7); 
        --s3: rgba(26, 30, 38, 0.6); 
        --s4: rgba(32, 37, 47, 0.5);
        --b1: rgba(255, 250, 245, 0.03); 
        --b2: rgba(255, 250, 245, 0.055); 
        --b3: rgba(255, 250, 245, 0.09);
        --tx: #eef1f6; 
        --mu: #5d6672; 
        --mu2: #8a919c;
        --gr: #5ba8a0; 
        --gr2: #3d8a80; 
        --gr3: #2a6158; 
        --grg: rgba(91, 168, 160, 0.1); 
        --grt: rgba(91, 168, 160, 0.05);
        --am: #c4a35a; --amg: rgba(196, 163, 90, 0.1);
        --co: #c47550; --cog: rgba(196, 117, 80, 0.1);
        --pu: #8b7ec9; --pug: rgba(139, 126, 201, 0.1);
        --bl: #5a9ed4; --blg: rgba(90, 158, 212, 0.1);
        --re: #c4546b; --reg: rgba(196, 84, 107, 0.1);
        --mo: 'Geist Mono', 'Berkeley Mono', 'Fira Code', 'JetBrains Mono', monospace;
        --nav: 200px; --par: 240px; --tokw: 240px;
      }
      body { 
        background: var(--bg); 
        color: var(--tx); 
        font-family: 'Geist', 'IBM Plex Sans', sans-serif; 
        font-size: 13px; 
        line-height: 1.5;
        height: 100vh;
        overflow: hidden;
        -webkit-font-smoothing: antialiased;
      }
      
      .shell { 
        display: flex; 
        height: 100vh; 
        overflow: hidden; 
        background: radial-gradient(circle at 50% -20%, #1a1e26 0%, var(--bg) 80%);
      }

      .nav { 
        width: var(--nav); 
        background: var(--s1); 
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-right: 1px solid var(--b2); 
        display: flex; 
        flex-direction: column; 
        flex-shrink: 0; 
        z-index: 20;
      }
      .nav-head { height: 48px; display: flex; align-items: center; padding: 0 16px; border-bottom: 1px solid var(--b2); gap: 10px; flex-shrink: 0; }
      .logo { font-size: 16px; font-weight: 600; letter-spacing: -0.03em; color: #fff; }
      .logo em { color: var(--gr); font-style: normal; }
      .epill { font-size: 9px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; background: var(--grg); color: var(--gr); border: 1px solid var(--gr3); padding: 2px 8px; border-radius: 20px; margin-left: auto; }
      
      .ns { padding: 12px 10px 4px; }
      .nl { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mu); padding: 0 8px; margin-bottom: 6px; }
      .ni { 
        display: flex; align-items: center; gap: 10px; padding: 6px 10px; border-radius: 8px; cursor: pointer; color: var(--mu2); font-size: 12px; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); white-space: nowrap; width: 100%; border: 1px solid transparent; background: transparent; text-align: left; font-family: inherit;
        margin-bottom: 2px;
      }
      .ni:hover { background: var(--b1); color: var(--tx); border-color: var(--b2); transform: translateX(2px); }
      .ni.on { background: var(--grt); color: var(--gr); border: 1px solid var(--gr3); }
      .ni svg { width: 14px; height: 14px; flex-shrink: 0; opacity: 0.7; transition: opacity 0.2s; }
      .ni:hover svg, .ni.on svg { opacity: 1; }
      
      .ndiv { height: 1px; background: var(--b2); margin: 8px 12px; }
      .nbot { margin-top: auto; padding: 12px; border-top: 1px solid var(--b2); background: rgba(0,0,0,0.2); }
      
      .fdir { font-size: 10px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--mu); padding: 6px 8px 2px; cursor: pointer; display: flex; align-items: center; gap: 6px; }
      .fdir:hover { color: var(--mu2); }
      .fr { display: flex; align-items: center; gap: 8px; padding: 5px 10px 5px 20px; border-radius: 6px; cursor: pointer; color: var(--mu2); font-size: 11px; font-family: var(--mo); transition: all 0.15s; width: 100%; border: none; background: transparent; text-align: left; }
      .fr:hover { background: var(--b1); color: var(--tx); }
      .fr.on { color: var(--gr); background: var(--grt); }
      .fdot { width: 4px; height: 4px; border-radius: 50%; background: currentColor; flex-shrink: 0; opacity: 0.5; }
      .famd { width: 6px; height: 6px; border-radius: 50%; background: var(--am); margin-left: auto; flex-shrink: 0; }

      .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; position: relative; }
      .tbar { 
        height: 48px; background: var(--s1); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-bottom: 1px solid var(--b2); display: flex; align-items: center; padding: 0 16px; gap: 12px; flex-shrink: 0; z-index: 15;
      }
      .vtog { display: flex; background: var(--s4); border: 1px solid var(--b3); border-radius: 8px; padding: 2px; gap: 2px; }
      .vb { font-size: 11px; padding: 5px 14px; border-radius: 6px; cursor: pointer; border: none; background: transparent; color: var(--mu2); font-family: inherit; transition: all 0.2s; position: relative; font-weight: 500; }
      .vb.on { background: var(--s1); color: var(--tx); border: 1px solid var(--b2); }
      .vb.stale::after { content: ''; position: absolute; top: 4px; right: 4px; width: 6px; height: 6px; border-radius: 50%; background: var(--am); }
      
      .tfile { font-size: 12px; color: var(--tx); font-family: var(--mo); font-weight: 500; opacity: 0.9; }
      .tver { font-size: 10px; color: var(--mu2); background: var(--s4); border: 1px solid var(--b2); padding: 2px 8px; border-radius: 4px; font-family: var(--mo); }
      .tright { margin-left: auto; display: flex; align-items: center; gap: 8px; }
      
      .btn { 
        font-size: 11px; font-weight: 500; padding: 6px 14px; border-radius: 8px; cursor: pointer; border: 1px solid var(--b3); background: var(--s3); color: var(--tx); font-family: inherit; transition: all 0.2s; white-space: nowrap; 
      }
      .btn:hover { background: var(--s4); border-color: var(--mu); transform: translateY(-1px); }
      .btn:active { transform: translateY(0); }
      .btn-gr { background: var(--grg); color: var(--gr); border-color: var(--gr3); }
      .btn-gr:hover { background: rgba(45, 212, 191, 0.2); border-color: var(--gr2); }
      .btn-am { background: var(--amg); color: var(--am); border-color: rgba(251, 191, 36, 0.3); }
      .btn-edit { background: var(--pug); color: var(--pu); border-color: rgba(167, 139, 250, 0.3); }
      .btn-edit:hover { background: rgba(167, 139, 250, 0.25); }

      .work { flex: 1; display: flex; overflow: hidden; min-height: 0; position: relative; }
      .epane { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; background: transparent; }

      .sbanner { 
        display: none; align-items: center; gap: 12px; padding: 8px 16px; background: var(--s2); border-bottom: 1px solid var(--b2); flex-shrink: 0; animation: slideDown 0.3s ease-out;
      }
      @keyframes slideDown { from { transform: translateY(-100%); } to { transform: translateY(0); } }
      .sbanner.show { display: flex; }
      .sdot { width: 6px; height: 6px; border-radius: 50%; background: var(--am); flex-shrink: 0; }
      .slabel { font-size: 12px; color: var(--mu2); }
      .slabel em { color: var(--am); font-style: normal; font-weight: 500; }
      .sacts { margin-left: auto; display: flex; gap: 8px; }

      .crow { display: none; align-items: center; gap: 10px; padding: 8px 16px; background: var(--s3); border-bottom: 1px solid var(--b2); flex-shrink: 0; }
      .crow.show { display: flex; }
      .clbl { font-size: 11px; color: var(--mu2); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
      .vops { display: flex; gap: 4px; }
      .vbtn { font-size: 11px; padding: 4px 10px; border-radius: 6px; cursor: pointer; border: 1px solid var(--b3); background: var(--s4); color: var(--mu2); font-family: inherit; transition: all 0.2s; }
      .vbtn.on { background: var(--grg); color: var(--gr); border-color: var(--gr3); }
      .vprev { font-size: 11px; font-family: var(--mo); color: var(--mu2); margin-left: 8px; }
      .vprev span { color: var(--gr); font-weight: 600; }

      .cscroll { flex: 1; overflow-y: auto; padding: 16px 0; scrollbar-gutter: stable; }
      .cscroll::-webkit-scrollbar { width: 6px; }
      .cscroll::-webkit-scrollbar-thumb { background: var(--b3); border-radius: 10px; }
      .cscroll::-webkit-scrollbar-track { background: transparent; }

      .error-banner { 
        display: flex; align-items: flex-start; gap: 14px; padding: 14px 20px; background: var(--reg); border-bottom: 1px solid rgba(244, 63, 94, 0.3); backdrop-filter: blur(5px);
      }
      .error-icon { width: 22px; height: 22px; border-radius: 50%; background: var(--re); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; flex-shrink: 0; }
      .error-content { flex: 1; min-width: 0; }
      .error-type { font-size: 10px; font-weight: 700; color: var(--re); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 2px; }
      .error-message { font-size: 13px; color: var(--tx); font-family: var(--mo); word-break: break-word; line-height: 1.5; opacity: 0.9; }

      .ced { font-family: var(--mo); font-size: 15px; line-height: 1.3; }
      .cl { display: flex; align-items: flex-start; position: relative; cursor: pointer; transition: background 0.1s; }
      .cl:hover .cc { background: rgba(255, 255, 255, 0.02); }
      .cl.hl-gr { background: rgba(45, 212, 191, 0.08); border-left: 3px solid var(--gr); align-items: center; }
      .cl.hl-am { background: rgba(251, 191, 36, 0.08); border-left: 3px solid var(--am); }
      .cl.hl-bl { background: rgba(56, 189, 248, 0.08); border-left: 3px solid var(--bl); }
      .cl.hl-pu { background: rgba(167, 139, 250, 0.08); border-left: 3px solid var(--pu); }
      .cl.ann { background: var(--s2); cursor: pointer; border-left: 0; margin: 4px 16px; border-radius: 8px; border: 1px solid var(--b2); }
      .cl.ann:hover { background: var(--s3); border-color: var(--b3); }
      .cl.collapsed { display: none; }
      .cl.cl-empty, .cl.cl-empty .ln, .cl.cl-empty .cc { line-height: 0.75; }
      .ln { width: 50px; text-align: right; padding-right: 20px; color: var(--mu); font-size: 11px; opacity: 0.4; flex-shrink: 0; user-select: none; line-height: 1.3; font-weight: 500; }
      .cc { flex: 1; padding-right: 24px; white-space: pre-wrap; word-break: break-word; color: var(--tx); position: relative; line-height: 1.3; }
      .edit-form { flex: 1; padding-right: 24px; }
      .edit-input { 
        width: 100%; background: var(--s4); border: 1px solid var(--pu); border-radius: 4px; outline: none; color: var(--tx); font-family: var(--mo); font-size: 15px; line-height: 1.3; padding: 0 4px; margin: 0; box-sizing: border-box; white-space: pre;
      }
      .ann .cc { color: var(--mu2); font-size: 11px; font-style: italic; padding: 1px 0; display: flex; align-items: center; gap: 6px; }
      .chev { font-size: 10px; color: var(--mu); transition: transform 0.15s; margin-left: auto; padding-right: 4px; flex-shrink: 0; }
      .chev.open { transform: rotate(90deg); }

      .mlist { margin: 0.6em 0 0.6em 2em; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.2em; line-height: 1.3; }
      .mlist li { display: flex; align-items: flex-start; gap: 0; }
      .mlist li::before { content: "•"; color: var(--mu); flex-shrink: 0; width: 1.2em; text-align: center; }
      .mlist li .cc { padding-left: 0.5em; }
      .mlist li.hl-gr { background: rgba(29, 158, 117, 0.05); border-left: 2px solid var(--gr); margin-left: 0; }
      .mlist li.hl-bl { background: rgba(74, 158, 221, 0.05); border-left: 2px solid var(--bl); }

      /* Markdown rendered content */
      .mhead { font-weight: 600; }
      .msec { background: var(--s2); padding: 4px 10px; margin: 8px 0 4px; border-radius: 4px; cursor: pointer; display: flex; flex-direction: column; align-items: stretch; gap: 4px; line-height: 1.3; }
      .msec-label { display: block; align-self: flex-start; }
      .msec-content { display: block; width: 100%; border-top: 0.5px solid var(--b1); padding-top: 4px; margin-top: 2px; line-height: 1.3; }
      .msec-content.collapsed { display: none; }
      .msec:hover { background: var(--s3); }
      .msec-label { font-size: 11px; background: var(--s3); padding: 2px 8px; border-radius: 3px; border: 0.5px solid var(--b2); position: relative; }      .msec.ab-gr .msec-label { background: var(--grt); border-color: rgba(29, 158, 117, 0.2); color: var(--gr); }
      .msec.ab-bl .msec-label { background: var(--blg); border-color: rgba(74, 158, 221, 0.2); color: var(--bl); }
      .msec.ab-pu .msec-label { background: var(--pug); border-color: rgba(139, 132, 232, 0.2); color: var(--pu); }
      .msec.ab-mu .msec-label { background: var(--mut); border-color: rgba(139, 139, 139, 0.2); color: var(--mu2); }
      .msec-chev { font-size: 10px; color: var(--mu); transition: transform 0.15s; }
      .msec-chev.open { transform: rotate(90deg); }

      .edit-mode .cc[contenteditable] { outline: none; border-radius: 2px; }
      .edit-mode .cc[contenteditable]:hover { background: rgba(139, 132, 232, 0.06); cursor: text; }
      .edit-mode .cc[contenteditable]:focus { background: rgba(139, 132, 232, 0.1); box-shadow: inset 0 0 0 1px rgba(139, 132, 232, 0.3); }

      /* Dropdown styles for headers */
      .dd-menu { display: none; position: absolute; background: var(--s2); border: 0.5px solid var(--b3); border-radius: 6px; padding: 4px; z-index: 100; max-height: 200px; overflow-y: auto; }
      .dd-menu.open { display: block; }
      .dd-option { padding: 6px 10px; border-radius: 4px; cursor: pointer; font-size: 11px; color: var(--mu2); transition: all 0.1s; font-family: var(--mo); white-space: nowrap; }
      .dd-option:hover { background: var(--s3); color: var(--tx); }
      .dd-option.selected { background: var(--grg); color: var(--gr); }

      .kw { color: var(--pu); }
      .vr { color: var(--gr); }
      .vl { color: var(--am); }
      .cm { color: var(--mu); font-style: italic; }
      .fs { color: var(--bl); }
      .fd { color: var(--co); }
      .rv { color: var(--am); background: rgba(239, 159, 39, 0.12); padding: 0 3px; border-radius: 3px; }
      .pv { color: var(--pu); font-style: italic; background: rgba(139, 132, 232, 0.15); padding: 0 2px; border-radius: 3px; }
      .rtv { color: var(--co); background: rgba(216, 90, 48, 0.15); padding: 0 3px; border-radius: 3px; }
      .va { color: var(--pu); font-size: 11px; }
      .ab { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; background: var(--s3); border: 0.5px solid var(--b2); padding: 2px 8px; border-radius: 3px; color: var(--mu2); font-style: normal; }
      .ab-gr { background: var(--grt); border-color: rgba(29, 158, 117, 0.2); color: var(--gr); }
      .ab-bl { background: var(--blg); border-color: rgba(74, 158, 221, 0.2); color: var(--bl); }
      .ab-pu { background: var(--pug); border-color: rgba(139, 132, 232, 0.2); color: var(--pu); }
      .ab-mu { background: var(--mut); border-color: rgba(139, 139, 139, 0.2); color: var(--mu2); }

      .sbar { height: 28px; background: var(--s1); border-top: 0.5px solid var(--b2); display: flex; align-items: center; padding: 0 14px; flex-shrink: 0; }
      .st { display: flex; align-items: center; gap: 5px; padding: 0 10px; border-right: 0.5px solid var(--b1); }
      .st:last-of-type { border-right: none; }
      .slb { font-size: 10px; color: var(--mu); letter-spacing: 0.05em; }
      .sv { font-size: 11px; font-weight: 500; font-family: var(--mo); }
      .sv-gr { color: var(--gr); }
      .sv-am { color: var(--am); }
      .sv-co { color: var(--co); }
      .sv-pu { color: var(--pu); }
      .sv-mu { color: var(--mu2); }
      .sright { margin-left: auto; display: flex; align-items: center; gap: 8px; }
      .sconndot { width: 5px; height: 5px; border-radius: 50%; background: var(--gr); }

      .tok-delta { display: flex; align-items: center; gap: 4px; font-size: 11px; font-family: var(--mo); font-weight: 500; }
      .tok-plus { color: var(--re); }
      .tok-minus { color: var(--gr); }

      .ppane { width: var(--par); background: var(--s1); border-left: 0.5px solid var(--b2); display: flex; flex-direction: column; flex-shrink: 0; overflow: hidden; transition: width 0.15s; }
      .ppane.closed { width: 0; border-left: none; }
      .ph { height: 42px; display: flex; align-items: center; padding: 0 12px; border-bottom: 0.5px solid var(--b2); flex-shrink: 0; }
      .ptitle { font-size: 10px; font-weight: 600; letter-spacing: 0.09em; text-transform: uppercase; color: var(--mu); }
      .pbody { flex: 1; overflow-y: auto; padding: 10px; }
      .pbody::-webkit-scrollbar { width: 3px; }
      .pbody::-webkit-scrollbar-thumb { background: var(--b2); border-radius: 2px; }
      .pgl { font-size: 9px; text-transform: uppercase; letter-spacing: 0.09em; color: var(--mu); margin: 10px 0 5px; padding: 0 2px; }
      .pgl:first-child { margin-top: 2px; }
      .pr { margin-bottom: 14px; display: flex; flex-direction: column; align-items: stretch; gap: 5px; position: relative; }
      .plbl { display: flex; align-items: center; gap: 6px; min-width: 0; }
      .pn { color: var(--gr); font-family: var(--mo); font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 500; }
      .pt { font-size: 9px; color: var(--mu2); background: var(--s3); border: 0.5px solid var(--b1); padding: 1px 5px; border-radius: 3px; white-space: nowrap; }
      .pi { width: 100%; background: var(--s3); border: 0.5px solid var(--b2); color: var(--tx); font-family: var(--mo); font-size: 11px; padding: 5px 8px; border-radius: 4px; outline: none; appearance: none; }      .pi:focus { border-color: var(--gr); }
      .pi.rt { cursor: pointer; border-style: dashed; }
      .pi.rt:hover { border-color: var(--mu2); background: var(--s2); }
      .pdiv { height: 0.5px; background: var(--b1); margin: 8px 0; }
      .tok-panel { display: none; width: var(--tokw); background: var(--s1); border-left: 0.5px solid var(--b2); flex-direction: column; flex-shrink: 0; overflow: hidden; transition: width 0.15s; }
      .tok-panel.open { display: flex; }
      .tp-head { height: 42px; display: flex; align-items: center; padding: 0 12px; border-bottom: 0.5px solid var(--b2); gap: 6px; flex-shrink: 0; }
      .tp-title { font-size: 10px; font-weight: 600; letter-spacing: 0.09em; text-transform: uppercase; color: var(--mu); }
      .tp-close { margin-left: auto; font-size: 11px; color: var(--mu); cursor: pointer; padding: 2px 6px; border-radius: 3px; }
      .tp-close:hover { background: var(--s3); color: var(--tx); }
      .tp-body { flex: 1; overflow-y: auto; padding: 12px; }
      .tp-body::-webkit-scrollbar { width: 3px; }
      .tp-body::-webkit-scrollbar-thumb { background: var(--b2); border-radius: 2px; }
      .tp-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 14px; }
      .tp-card { background: var(--s2); border: 0.5px solid var(--b1); border-radius: 6px; padding: 8px 10px; }
      .tp-cl { font-size: 9px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--mu); margin-bottom: 3px; }
      .tp-cv { font-size: 18px; font-weight: 500; font-family: var(--mo); }
      .tp-sec { margin-bottom: 12px; }
      .tp-sl { font-size: 10px; color: var(--mu2); margin-bottom: 6px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.07em; }
      .tp-track { height: 8px; background: var(--s3); border-radius: 4px; overflow: hidden; display: flex; gap: 1px; margin-bottom: 6px; }
      .tp-seg { height: 100%; }
      .tp-legend { display: flex; flex-direction: column; gap: 3px; }
      .tp-leg { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--mu2); }
      .tp-legdot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
      .tp-legval { margin-left: auto; font-family: var(--mo); font-size: 11px; color: var(--tx); }
      .tp-row { display: flex; justify-content: space-between; align-items: center; padding: 4px 0; border-bottom: 0.5px solid var(--b1); font-size: 11px; }
      .tp-row:last-child { border-bottom: none; }
      .tp-rl { color: var(--mu2); }
      .tp-rv { font-family: var(--mo); color: var(--tx); }

      .popover { display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: var(--s2); border: 0.5px solid var(--b3); border-radius: 7px; padding: 12px; z-index: 30; width: 240px; }
      .popover.show { display: block; }
      .dropdown-popover { position: absolute; top: 100%; left: 0; right: 0; transform: none; width: auto; margin-top: 4px; z-index: 40; }
      .popover-backdrop { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 29; }      .popover-backdrop.show { display: block; }
      .pop-head { font-size: 10px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mu); margin-bottom: 8px; display: flex; align-items: center; justify-content: space-between; }
      .pop-close { cursor: pointer; color: var(--mu); padding: 1px 5px; border-radius: 3px; }
      .pop-close:hover { background: var(--s3); color: var(--tx); }
      .pop-input { width: 100%; background: var(--s1); border: 0.5px solid var(--b3); color: var(--tx); font-family: var(--mo); font-size: 11px; padding: 6px 8px; border-radius: 4px; outline: none; margin-bottom: 8px; }
      .pop-input:focus { border-color: var(--gr); }
      .pop-flbl { font-size: 9px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--mu); margin-bottom: 5px; }
      .pf-row { display: flex; align-items: center; gap: 6px; padding: 5px 7px; border-radius: 4px; cursor: pointer; background: var(--s1); border: 0.5px solid var(--b1); margin-bottom: 3px; transition: all 0.1s; }
      .pf-row:hover { border-color: var(--gr2); background: var(--grt); }
      .pf-lbl { font-size: 11px; color: var(--mu2); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .pf-val { font-size: 10px; font-family: var(--mo); color: var(--tx); max-width: 80px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .pf-del { font-size: 11px; color: var(--mu); cursor: pointer; padding: 0 3px; opacity: 0; flex-shrink: 0; }
      .pf-row:hover .pf-del { opacity: 1; }
      .pop-save { width: 100%; font-size: 11px; padding: 5px; border-radius: 4px; cursor: pointer; border: 0.5px solid var(--b2); background: transparent; color: var(--mu2); font-family: inherit; transition: all 0.1s; margin-top: 2px; }
      .pop-save:hover { background: var(--s3); color: var(--tx); }

      /* LiveView specific indicators */
      .liveview-status {
        position: fixed;
        bottom: 10px;
        right: 10px;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 10px;
        z-index: 9999;
        font-family: var(--mo);
      }
      .liveview-connected { background: var(--grg); color: var(--gr); border: 0.5px solid var(--gr2); display: none; }
      .liveview-disconnected { background: var(--reg); color: var(--re); border: 0.5px solid var(--re); }
      .liveview-error { background: var(--amg); color: var(--am); border: 0.5px solid var(--am); }

      /* Markdown rendering */
      .markdown-body { color: var(--tx); font-family: var(--mo); font-size: 13px; line-height: 1.6; padding: 16px; }
      .markdown-body h1, .markdown-body h2, .markdown-body h3, .markdown-body h4, .markdown-body h5, .markdown-body h6 { color: var(--tx); margin: 1em 0 0.5em; font-weight: 600; }
      .markdown-body h1 { font-size: 1.5em; border-bottom: 1px solid var(--b2); padding-bottom: 0.3em; }
      .markdown-body h2 { font-size: 1.25em; }
      .markdown-body h3 { font-size: 1.1em; }
      .markdown-body p { margin: 0.8em 0; }
      .markdown-body ul, .markdown-body ol { margin: 0.8em 0; padding-left: 1.5em; }
      .markdown-body li { margin: 0.3em 0; }
      .markdown-body code { background: var(--s2); padding: 0.15em 0.4em; border-radius: 3px; font-size: 0.9em; color: var(--pu); }
      .markdown-body pre { background: var(--s2); padding: 1em; border-radius: 6px; overflow-x: auto; margin: 1em 0; }
      .markdown-body pre code { background: transparent; padding: 0; color: var(--tx); }
      .markdown-body blockquote { border-left: 4px solid var(--b3); margin: 1em 0; padding: 0.5em 1em; color: var(--mu); background: var(--s2); }
      .markdown-body hr { border: none; border-top: 1px solid var(--b2); margin: 1.5em 0; }
      .markdown-body strong { color: var(--tx); font-weight: 600; }
      .markdown-body em { color: var(--mu2); font-style: italic; }
      .markdown-body a { color: var(--bl); text-decoration: underline; }
      .markdown-body table { border-collapse: collapse; margin: 1em 0; width: 100%; }
      .markdown-body th, .markdown-body td { border: 1px solid var(--b2); padding: 0.5em 0.8em; text-align: left; }
      .markdown-body th { background: var(--s2); font-weight: 600; }

      .resizer {
        width: 4px;
        cursor: col-resize;
        background: transparent;
        transition: background 0.2s;
        z-index: 10;
        flex-shrink: 0;
      }
      .resizer:hover, .resizer:active {
        background: var(--bl);
      }
    </style>

  </head>
  <body class="h-full">
    <%= @inner_content %>
    
    <!-- Debug status indicator -->
    <div id="lv-status" class="liveview-status liveview-disconnected">LV: Initializing...</div>
    
    <script>
      window.addEventListener("phx:page-loading-start", _info => {
        const el = document.getElementById("lv-status");
        el.innerText = "LV: Loading...";
        el.className = "liveview-status liveview-error";
      });
      window.addEventListener("phx:page-loading-stop", _info => {
        const el = document.getElementById("lv-status");
        el.innerText = "LV: Connected";
        el.className = "liveview-status liveview-connected";
      });
    </script>
    <script src="/app.js"></script>
  </body>
</html>
