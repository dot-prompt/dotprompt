# Environment variables for Docker Compose
# Use a strong secret key for production (mix phx.gen.secret)
SECRET_KEY_BASE=SET_ME_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
LIVE_VIEW_SIGNING_SALT=SET_ME_TO_A_MEDIUM_LENGTH_RANDOM_STRING

# Port where Phoenix server will be accessible on the host
PROMPT_SERVER_PORT=4000

# Directory on the HOST that contains .prompt files
PROMPT_DIR_HOST=./prompts

# Public domain name for URL generation (if applicable)
# PHX_HOST=example.com
