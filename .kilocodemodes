            items: [
              { type: 'doc', docId: 'intro', label: 'Guides' },
              { to: '/api', label: 'API Reference' },
              { type: 'docsVersionDropdown' },
              { href: 'https://github.com/org/repo', label: 'GitHub', position: 'right' },
            ],
          },
